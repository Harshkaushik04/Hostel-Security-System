{
  "compilerOptions": {
    "target": "es2016",
    "module": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  },
  "include": [
    "**/*.ts"
